model Chunk {
    id        String                       @id @default(uuid())
    projectId String
    project   Project                      @relation(fields: [projectId], references: [id], onDelete: Cascade)
    filePath  String
    content   String
    startLine Int
    endLine   Int
    embedding Unsupported("vector(1024)")?
    createdAt DateTime                     @default(now())

    @@index([projectId])
}
